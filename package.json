{
  "name": "blacket-claimer",
  "version": "2.0.0",
  "description": "Secure multi-user Discord bot for Blacket daily claiming",
  "main": "dist/main.js",
  "scripts": {
    "build": "bunx prisma generate && bunx tsc -p tsconfig.json",
    "check": "bunx biome check .",
    "db:generate": "bunx prisma generate",
    "db:push": "touch prisma/blacket.db && bunx prisma db push",
    "dev": "bun --watch src/main.ts",
    "format": "bunx biome format --write .",
    "lint": "bunx biome lint .",
    "start": "bun dist/main.js"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@prisma/client": "6.16.3",
    "discord.js": "^14.19.3",
    "dotenv": "^16.4.7",
    "necord": "^6.8.7",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/node": "^22.13.10",
    "prisma": "6.16.3",
    "typescript": "^5.8.2"
  }
}
